---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import exifr from 'exifr';
import fs from 'node:fs';

const posts = await getCollection('blog');

// Magie: Extrakce GPS dat z fotek během buildu
const mapPoints = await Promise.all(posts.map(async (post) => {
  const imagePath = `./public${post.data.image_main}`;
  let coords = null;
  
  try {
    if (fs.existsSync(imagePath)) {
      const data = await exifr.gps(imagePath);
      if (data) coords = [data.latitude, data.longitude];
    }
  } catch (e) {
    console.log("GPS nenalezeno u:", post.data.image_main);
  }

  return {
    title: post.data.title,
    location: post.data.location_name,
    coords: coords
  };
}));

// Vyfiltrujeme jen příspěvky, co mají GPS
const validPoints = mapPoints.filter(p => p.coords);
---

<Layout title="Taiwan & Korea 2026">
	<main>
		<section class="hero">
			<h1>🇹🇼 Taiwan & Korea 🇰🇷</h1>
			<p class="subtitle">Cestovatelský deník</p>
		</section>

		<div id="map" style="height: 400px; border-radius: 1rem; margin-bottom: 2rem;"></div>

		<section class="posts-grid">
			{posts.map(post => (
				<article class="card">
					<img src={post.data.image_main} alt={post.data.title} class="main-img" />
					<h2>{post.data.title}</h2>
					<p class="loc">📍 {post.data.location_name}</p>
					<div class="content">
						{post.body}
					</div>
				</article>
			))}
		</section>
	</main>

	<script is:inline define:vars={{ validPoints }}>
		// Inicializace mapy Leaflet
		const map = L.map('map').setView([24.0, 121.0], 6); // Centrováno na Taiwan
		L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png').addTo(map);

		const lineCoords = [];

		validPoints.forEach(point => {
			L.marker(point.coords).addTo(map)
				.bindPopup(`<b>${point.title}</b><br>${point.location}`);
			lineCoords.push(point.coords);
		});

		// Nakreslí čáru trasy
		if (lineCoords.length > 1) {
			L.polyline(lineCoords, {color: '#00fbff', weight: 3}).addTo(map);
			map.fitBounds(L.polyline(lineCoords).getBounds());
		}
	</script>
</Layout>

<style>
	/* ... tvoje existující styly + přidáme ... */
	.main-img { width: 100%; border-radius: 0.5rem; margin-bottom: 1rem; }
	.card { background: #1a1d23; padding: 1.5rem; margin-bottom: 2rem; border-radius: 1rem; }
	.loc { color: #00fbff; font-weight: bold; }
</style>
