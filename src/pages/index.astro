---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import exifr from 'exifr';
import fs from 'node:fs';

const posts = await getCollection('blog');

// Extrakce GPS dat z fotek během buildu
const mapPoints = await Promise.all(posts.map(async (post) => {
  const imagePath = `./public${post.data.image_main}`;
  let coords = null;
  
  try {
    if (fs.existsSync(imagePath)) {
      const data = await exifr.gps(imagePath);
      if (data) coords = [data.latitude, data.longitude];
    }
  } catch (e) {
    console.log("GPS nenalezeno u:", post.data.image_main);
  }

  return {
    title: post.data.title,
    location: post.data.location_name,
    coords: coords
  };
}));

const validPoints = mapPoints.filter(p => p.coords);
---

<Layout title="Taiwan & Korea 2026">
	<main>
		<section class="hero">
			<h1>🇹🇼 Taiwan & Korea 🇰🇷</h1>
			<p class="subtitle">Cestovatelský deník</p>
		</section>

		<div id="map"></div>

		<section class="posts-grid">
			{posts.map(post => (
				<article class="card">
					<img src={post.data.image_main} alt={post.data.title} class="main-img" />
					<h2>{post.data.title}</h2>
					<p class="loc">📍 {post.data.location_name}</p>
					<div class="content">
						{post.body}
					</div>
				</article>
			))}
		</section>
	</main>

	<script is:inline define:vars={{ validPoints }}>
		// Inicializace mapy
		const map = L.map('map').setView([25, 121], 5); 
		L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
			attribution: '&copy; OpenStreetMap'
		}).addTo(map);

		const lineCoords = [];

		validPoints.forEach(point => {
			L.marker(point.coords).addTo(map)
				.bindPopup(`<b>${point.title}</b><br>${point.location}`);
			lineCoords.push(point.coords);
		});

		if (lineCoords.length > 0) {
			const polyline = L.polyline(lineCoords, {color: '#00fbff', weight: 3}).addTo(map);
			map.fitBounds(polyline.getBounds(), { padding: [50, 50] });
		}
	</script>
</Layout>

<style>
	main { margin: auto; padding: 2rem; width: 800px; max-width: calc(100% - 2rem); color: #e0e0e0; font-family: sans-serif; }
	.hero { text-align: center; padding: 2rem 0; }
	h1 { font-size: 3rem; background: linear-gradient(45deg, #ff0055, #00fbff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
	#map { height: 400px; border-radius: 1.5rem; margin-bottom: 2rem; border: 1px solid #333; }
	.card { background: #1a1d23; padding: 2rem; border-radius: 1.5rem; border: 1px solid #333; margin-bottom: 2rem; }
	.main-img { width: 100%; border-radius: 1rem; margin-bottom: 1.5rem; border: 1px solid #444; }
	.loc { color: #00fbff; font-weight: bold; margin-bottom: 1rem; }
	.content { line-height: 1.6; color: #ccc; }
</style>
