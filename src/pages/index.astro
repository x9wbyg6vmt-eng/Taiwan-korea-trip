---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import exifr from 'exifr';
import fs from 'node:fs';

// Načtení příspěvků
const posts = await getCollection('blog');

// Extrakce GPS dat
const mapPoints = await Promise.all(posts.map(async (post) => {
  const imagePath = `./public${post.data.image_main}`;
  let coords = null;
  
  try {
    if (fs.existsSync(imagePath)) {
      const data = await exifr.gps(imagePath);
      if (data) coords = [data.latitude, data.longitude];
    }
  } catch (e) {
    console.log("GPS nenalezeno");
  }

  return {
    title: post.data.title,
    location: post.data.location_name,
    coords: coords
  };
}));

const validPoints = mapPoints.filter(p => p.coords);
---

<Layout title="Taiwan & Korea 2026">
	<main>
		<header class="hero">
			<h1>🇹🇼 Taiwan & Korea 🇰🇷</h1>
			<p class="subtitle">Cestovatelský deník</p>
		</header>

		<div id="map-container">
			<div id="map"></div>
		</div>

		<section class="posts">
			{posts.length === 0 && <p class="warning">Zatím žádné příspěvky. Zkontrolujte složku src/content/blog/</p>}
			
			{posts.map(post => (
				<article class="post-card">
					<img src={post.data.image_main} alt={post.data.title} />
					<div class="post-content">
						<span class="badge">📍 {post.data.location_name}</span>
						<h2>{post.data.title}</h2>
						<div class="text">{post.body}</div>
					</div>
				</article>
			))}
		</section>
	</main>
</Layout>

<script is:inline define:vars={{ validPoints }}>
	// Inicializace mapy s ochranou proti chybě
	const map = L.map('map').setView([23.5, 121], 6);
	
	L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
		attribution: '&copy; OpenStreetMap contributors'
	}).addTo(map);

	if (validPoints.length > 0) {
		const coords = validPoints.map(p => p.coords);
		validPoints.forEach(p => {
			L.marker(p.coords).addTo(map).bindPopup(`<b>${p.title}</b><br>${p.location}`);
		});
		if (coords.length > 1) {
			L.polyline(coords, {color: '#00fbff', weight: 3}).addTo(map);
		}
		map.fitBounds(L.polyline(coords).getBounds(), { padding: [50, 50] });
	}
</script>

<style>
	main {
		margin: auto;
		padding: 1rem;
		width: 800px;
		max-width: calc(100% - 2rem);
	}
	.hero { text-align: center; padding: 2rem 0; }
	h1 { font-size: 3.5rem; margin: 0; background: linear-gradient(45deg, #ff0055, #00fbff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
	.subtitle { color: #888; font-size: 1.2rem; text-transform: uppercase; letter-spacing: 2px; }
	
	#map-container {
		background: #1a1d23;
		padding: 10px;
		border-radius: 20px;
		box-shadow: 0 10px 30px rgba(0,0,0,0.5);
		margin-bottom: 3rem;
	}
	#map { height: 450px; border-radius: 15px; }

	.post-card {
		background: #1a1d23;
		border-radius: 20px;
		overflow: hidden;
		margin-bottom: 3rem;
		border: 1px solid #333;
	}
	.post-card img { width: 100%; height: auto; display: block; }
	.post-content { padding: 2rem; }
	.badge { background: #00fbff22; color: #00fbff; padding: 5px 12px; border-radius: 20px; font-weight: bold; font-size: 0.9rem; }
	h2 { margin: 1rem 0; font-size: 2rem; }
	.text { color: #ccc; line-height: 1.8; font-size: 1.1rem; }
	.warning { text-align: center; color: #ff0055; background: #ff005511; padding: 1rem; border-radius: 10px; }
</style>
