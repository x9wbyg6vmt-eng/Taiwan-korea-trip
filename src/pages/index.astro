---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import exifr from 'exifr';
import fs from 'node:fs';

const posts = await getCollection('blog');
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

const mapPoints = await Promise.all(posts.map(async (post) => {
  const imagePath = `./public${post.data.image_main}`;
  let coords = null;
  try {
    if (fs.existsSync(imagePath)) {
      const data = await exifr.gps(imagePath);
      if (data) coords = [data.latitude, data.longitude];
    }
  } catch (e) {}
  return { title: post.data.title, location: post.data.location_name, coords: coords };
}));

const validPoints = mapPoints.filter(p => p.coords);
---

<Layout title="Journey Atlas | Taiwan + Korea">
	<main>
		<header class="hero">
			<p class="tiny-label">Private Travel Journal</p>
			<h1>Taiwan & Korea</h1>
			<div class="accent-line"></div>
		</header>

		<section id="map-section">
			<div id="map"></div>
		</section>

		<section class="journal-feed">
			{posts.map(post => {
				const mainImg = `${baseUrl}/${post.data.image_main.replace(/^\//, '')}`;
				return (
					<article class="journal-entry">
						<div class="entry-header">
							<span class="location-badge">{post.data.location_name}</span>
							<h2>{post.data.title}</h2>
						</div>

						<div class="gallery-stack">
							<img src={mainImg} alt="" class="main-image" />
							
							{(post.data.image_sub1 || post.data.image_sub2) && (
								<div class="sub-images">
									{post.data.image_sub1 && <img src={`${baseUrl}/${post.data.image_sub1.replace(/^\//, '')}`} alt="" />}
									{post.data.image_sub2 && <img src={`${baseUrl}/${post.data.image_sub2.replace(/^\//, '')}`} alt="" />}
								</div>
							)}
						</div>

						<div class="entry-body">
							{post.body}
						</div>
					</article>
				)
			})}
		</section>
	</main>
</Layout>

<script is:inline define:vars={{ validPoints }}>
	const map = L.map('map', { zoomControl: false }).setView([23.5, 121], 6);
	L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png').addTo(map);

	if (validPoints.length > 0) {
		const coords = validPoints.map(p => p.coords);
		validPoints.forEach(p => {
			L.circleMarker(p.coords, { color: '#A3C1AD', radius: 6, fillOpacity: 0.8 }).addTo(map)
				.bindPopup(`<b style="color:#161311">${p.title}</b>`);
		});
		if (coords.length > 1) {
			L.polyline(coords, { color: '#A3C1AD', weight: 1, dashArray: '5, 10' }).addTo(map);
			map.fitBounds(L.polyline(coords).getBounds(), { padding: [50, 50] });
		}
	}
</script>

<style>
	main { margin: auto; padding: 2rem; width: 700px; max-width: calc(100% - 4rem); }
	
	.hero { text-align: center; padding: 4rem 0; }
	.tiny-label { font-size: 12px; letter-spacing: 3px; color: var(--color-accent); text-transform: uppercase; margin-bottom: 1rem; }
	h1 { font-family: var(--font-display); font-size: 4rem; font-weight: 400; margin: 0; font-style: italic; }
	.accent-line { width: 40px; height: 1px; background: var(--color-accent); margin: 2rem auto; }

	#map-section { background: var(--color-surface-2); padding: 10px; border-radius: 2px; margin-bottom: 5rem; }
	#map { height: 400px; filter: grayscale(0.5) contrast(1.1); }

	.journal-entry { margin-bottom: 8rem; }
	.entry-header { margin-bottom: 2rem; }
	.location-badge { font-size: 12px; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 1px; }
	h2 { font-family: var(--font-display); font-size: 2.5rem; font-weight: 400; margin: 0.5rem 0; }

	.gallery-stack { display: flex; flex-direction: column; gap: 10px; margin-bottom: 2rem; }
	.main-image { width: 100%; border-radius: 2px; }
	.sub-images { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
	.sub-images img { width: 100%; height: 200px; object-fit: cover; border-radius: 2px; }

	.entry-body { font-size: 1.1rem; line-height: 1.8; color: var(--color-text-muted); white-space: pre-wrap; }
</style>
